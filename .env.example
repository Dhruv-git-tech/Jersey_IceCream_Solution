# =============================================================================
# Jersey Ice Cream Demand Intelligence Platform — Environment Variables
# =============================================================================
# Copy this file to .env and fill in actual values.
# NEVER commit .env to version control.
# =============================================================================

# ─── Application ─────────────────────────────────────────────────────────────
APP_NAME=Jersey Ice Cream Platform
APP_ENV=development
APP_DEBUG=true
APP_VERSION=0.1.0
APP_HOST=0.0.0.0
APP_PORT=8000
APP_WORKERS=4

# ─── Security ────────────────────────────────────────────────────────────────
SECRET_KEY=change-this-to-a-64-char-random-string-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# ─── PostgreSQL ──────────────────────────────────────────────────────────────
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=jersey
POSTGRES_PASSWORD=jersey_secure_password_change_me
POSTGRES_DB=jersey_platform
DATABASE_URL=postgresql+asyncpg://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}
DATABASE_URL_SYNC=postgresql+psycopg2://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}

# ─── Redis ───────────────────────────────────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_URL=redis://${REDIS_HOST}:${REDIS_PORT}/${REDIS_DB}

# ─── Kafka ───────────────────────────────────────────────────────────────────
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_GROUP_ID=jersey-platform
KAFKA_AUTO_OFFSET_RESET=earliest

# ─── MinIO (S3-Compatible Object Storage) ────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_CART_PHOTOS=cart-photos
MINIO_BUCKET_MODEL_ARTIFACTS=model-artifacts
MINIO_USE_SSL=false

# ─── External APIs ──────────────────────────────────────────────────────────
WEATHER_API_KEY=your_openweathermap_api_key
WEATHER_API_BASE_URL=https://api.openweathermap.org/data/2.5

# WhatsApp Business API (Meta Cloud API)
WHATSAPP_API_TOKEN=your_whatsapp_business_api_token
WHATSAPP_PHONE_NUMBER_ID=your_phone_number_id
WHATSAPP_VERIFY_TOKEN=your_webhook_verify_token

# ─── AI / ML ────────────────────────────────────────────────────────────────
YOLO_MODEL_PATH=./ai/models/yolo/weights/best.pt
YOLO_CONFIDENCE_THRESHOLD=0.6
FORECAST_MODEL_PATH=./ai/models/forecasting/weights/

# ─── Observability ──────────────────────────────────────────────────────────
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=jersey-backend
LOG_LEVEL=INFO
PROMETHEUS_PORT=9090

# ─── Rate Limiting ──────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS_PER_MINUTE=60
RATE_LIMIT_BURST=10
